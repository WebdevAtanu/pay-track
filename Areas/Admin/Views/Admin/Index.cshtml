@model List<payroll_mvc.Areas.Admin.Models.AdminViewModel>

<div class="d-flex justify-content-between align-items-center mb-2 p-1 bg-white shadow-sm rounded">

    <!-- Left Section -->
    <div>
        <h5 class="fw-bold mb-0 text-dark">Welcome, @(User.Identity.IsAuthenticated? User.Identity.Name : "Guest")</h5>
        <small class="text-muted">@DateTime.Now.ToString("yyyy-MM-dd")</small>
    </div>

    <!-- Right Section (Avatar + Name) -->
    <div class="btn-group">
        <button type="button"
                class="btn p-0 border-0 dropdown-toggle-split avatar-trigger"
                data-bs-toggle="dropdown"
                aria-expanded="false">
            <img src="~/images/avatar.jpg"
                 alt="avatar"
                 class="rounded-circle border border-2 border-white shadow-sm"
                 width="45" height="45">
        </button>

        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-1 mt-1 rounded-1">
            <li><h6 class="dropdown-header fw-bold text-dark small">Account Settings</h6></li>
            <li><hr class="dropdown-divider"></li>
            <li><button class="dropdown-item rounded-1 py-1" type="button">Action</button></li>
            <li><button class="dropdown-item rounded-1 py-1" type="button">Another action</button></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item rounded-1 py-1 bg-danger text-white fw-semibold" asp-action="Logout">Logout</a></li>
        </ul>
    </div>

</div>

<h1>Admin Dashboard</h1>

<div class="">
    <table class="table table-striped">
        <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Password</th>
        </tr>
        @foreach (var admin in Model)
        {
            <tr>
                <td>@admin.Name</td>
                <td>@admin.Phone</td>
                <td>@admin.Email</td>
                <td>@admin.Password</td>
            </tr>
        }
    </table>
</div>