@model List<DepartmentViewModel>

@{
    ViewData["Title"] = "Department";
}

<div class="container mt-2">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="fw-bold">Department List</h4>
        <a asp-action="add" class="btn btn-primary shadow-sm">+ Add Department</a>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm">
        <div class="card-body table-responsive p-0" style="max-height:600px;">

            <table class="table table-hover align-middle">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var statusClass = item.IsActive == true ? "text-success fw-semibold" : "text-danger fw-semibold";
                            var statusText = item.IsActive == true ? "Active" : "Inactive";

                            <tr>
                                <td>@item.DeptCode</td>
                                <td>@item.DeptName</td>
                                <td class="@statusClass">
                                    <form asp-action="ActiveToggle" asp-route-id="@item.DeptId" method="post" style="display:inline;" class="@statusClass">
                                        <button type="submit" class="border-0 bg-white @statusClass">
                                            @statusText
                                        </button>
                                    </form>
                                </td>
                                <td class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.DeptId" class="btn btn-sm btn-warning w-full">Edit</a>
                                    <button type="button"
                                            class="btn btn-sm btn-danger w-full"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-id="@item.DeptId">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">
                                No department found
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>
