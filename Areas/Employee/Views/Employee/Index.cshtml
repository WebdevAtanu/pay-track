@model IEnumerable<EmployeeViewModel>

@{
    ViewData["Title"] = "Employees";
}

<div class="container mt-2">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="fw-bold">Employee List</h4>
        <a asp-action="add" class="btn btn-primary shadow-sm">+ Add Employee</a>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm">
        <div class="card-body table-responsive p-0" style="max-height:600px;">

            <table class="table table-hover align-middle">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Joining Date</th>
                        <th>Salary</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var statusClass = item.IsActive == true ? "text-success fw-semibold" : "text-danger fw-semibold";
                            var statusText = item.IsActive == true ? "Active" : "Inactive";

                            <tr>
                                <td>@item.EmpCode</td>
                                <td>@item.Name</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>@item.DepartmentName</td>
                                <td>@item.JoiningDate?.ToString("yyyy-mm-dd")</td>
                                <td>₹ @item.BasicSalary</td>
                                <td class="@statusClass">
                                    @* <a asp-action="ActiveToggle" asp-route-id="@item.EmployeeId" class="@statusClass">@statusText</a> *@

                                    <form asp-action="ActiveToggle" asp-route-id="@item.EmployeeId" method="post" style="display:inline;" class="@statusClass">
                                        <button type="submit" class="border-0 bg-white @statusClass">
                                            @statusText
                                        </button>
                                    </form>
                                </td>
                                <td class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.EmployeeId" class="btn btn-sm btn-warning w-full">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@item.EmployeeId" method="post" style="display:inline;" class="w-full">
                                        <button type="button"
                                                class="btn btn-sm btn-danger w-full"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@item.EmployeeId">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">
                                No employees found
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>


@* ========================================= confirm delete modal =================================== *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete this employee?
            </div>

            <div class="modal-footer">
                <form id="deleteForm" method="post">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>

        </div>
    </div>
</div>