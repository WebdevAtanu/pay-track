@model CardData;

<div class="col-md-3">
    <div class="card shadow-sm border-0 rounded-3 p-2">
        <div class="d-flex align-items-center gap-3">

            <div class="@Model.ColorClass bg-opacity-100 text-white d-flex align-items-center justify-content-center rounded-3"
                 style="width:60px; height:60px;">
                <i class="@Model.IconClass fs-4"></i>
            </div>

            <div>
                <h6 class="text-muted mb-1">@Model.Title</h6>
                <h3 class="fw-bold mb-0">₹@Model.Value</h3>
            </div>

        </div>
    </div>
</div>