@{
    ViewData["Title"] = "Dashboard";
}
@model DashboardViewModel

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-2 p-1 bg-white shadow-sm rounded">

        <!-- Left Section -->
        <div>
            <h2 class="fw-bold mb-0">Dashboard</h2>
            <small class="text-muted">Welcome back, Admin</small>
        </div>

        <!-- Right Section (Avatar + Name) -->
        <div class="d-flex align-items-center gap-3">

            <!-- User Info -->
            <div class="text-end">
                <div class="fw-semibold">Admin</div>
                <small class="text-muted">Administrator</small>
            </div>

            <!-- Avatar -->
            <img src="https://i.pravatar.cc/40"
                 alt="avatar"
                 class="rounded-circle border"
                 width="45"
                 height="45"
                 style="object-fit: cover;">
        </div>

    </div>

    <!-- Stats Cards -->

    <div class="row g-4">

        @await Html.PartialAsync("_Card", new CardData {
        Title = "Total Employees",
                Value = Model.EmployeeCount.ToString(),
                IconClass = "bi bi-people-fill",
                ColorClass = "bg-primary"
                })

        @await Html.PartialAsync("_Card", new CardData {
                Title = "Total Salary",
                Value = Model.TotalSalary.ToString(),
                IconClass = "bi bi-cash-stack",
                ColorClass = "bg-danger"
                })

        @await Html.PartialAsync("_Card", new CardData {
                Title = "Settled Salary",
                Value = Model.SettledSalary.ToString(),
                IconClass = "bi bi-check-circle",
                ColorClass = "bg-warning"
                })

        @await Html.PartialAsync("_Card", new CardData {
                Title = "Pending Salary",
                Value = Model.PendingSalary.ToString(),
                IconClass = "bi bi-exclamation-circle",
                ColorClass = "bg-info"
                })
    </div>

    <!-- Quick Actions -->
    @* <div class="mt-4">
        <h4 class="mb-3">Quick Actions</h4>

        <div class="row g-3">

            <div class="col-md-3">
                <a href="/Employee/Create" class="btn btn-primary w-100 p-3">
                    ➕ Add Employee
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Payroll/Generate" class="btn btn-success w-100 p-3">
                    💰 Generate Payroll
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Reports" class="btn btn-warning w-100 p-3">
                    📊 View Reports
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Settings" class="btn btn-dark w-100 p-3">
                    ⚙️ Settings
                </a>
            </div>

        </div>
    </div> *@

    <!-- Recent Payroll Table -->
    <div class="mt-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5>Recent Payrolls</h5>
            <a asp-area="Employee" asp-controller="Employee" asp-action="Index" class="btn border px-4 py-2 text-decoration-none">View All</a>
        </div>

        @if (Model.RecentPayrolls == null || Model.RecentPayrolls.Count == 0)
        {
            <h5 class="text-muted">No recent payrolls available</h5>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-body p-0 table-responsive" style=" max-height:400px;">
                    <table class="table table-hover">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Employee</th>
                                <th>Month</th>
                                <th>Basic</th>
                                <th>Deductions</th>
                                <th>Net Salary</th>
                            </tr>
                        </thead>
                        <tbody class="">
                            @foreach (var payroll in Model.RecentPayrolls)
                            {
                                <tr>
                                    <td>@payroll.Name</td>
                                    <td>@payroll.Month</td>
                                    <td>₹@payroll.Gross</td>
                                    <td>₹@payroll.Deduction</td>
                                    <td class="fw-bold">₹@payroll.Net</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
