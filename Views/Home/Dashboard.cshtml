@{
    ViewData["Title"] = "Dashboard";
}
@model DashboardViewModel

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-2 p-1 bg-white shadow-sm rounded">

    <!-- Left Section -->
    <div>
        <h5 class="fw-bold mb-0 text-dark">Welcome, @(User.Identity.IsAuthenticated? User.Identity.Name : "Guest")</h5>
        <small class="text-muted">@DateTime.Now.ToString("yyyy-MM-dd")</small>
    </div>

    <!-- Right Section (Avatar + Name) -->
    <div class="btn-group">
        <button type="button"
                class="btn p-0 border-0 dropdown-toggle-split avatar-trigger"
                data-bs-toggle="dropdown"
                aria-expanded="false">
            <img src="~/images/avatar.jpg"
                 alt="avatar"
                 class="rounded-circle border border-2 border-white shadow-sm"
                 width="45" height="45">
        </button>

        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-1 mt-1 rounded-1">
            <li><h6 class="dropdown-header fw-bold text-dark small">Account Settings</h6></li>
            <li><hr class="dropdown-divider"></li>
            <li><button class="dropdown-item rounded-1 py-1" type="button">Action</button></li>
            <li><button class="dropdown-item rounded-1 py-1" type="button">Another action</button></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item rounded-1 py-1 bg-danger text-white fw-semibold" asp-action="Logout">Logout</a></li>
        </ul>
    </div>

</div>

<!-- Stats Cards -->

<div class="row g-2">

    @await Html.PartialAsync("_Card", new CardData {
    Title = "Total Employees",
        Value = Model.EmployeeCount.ToString(),
        IconClass = "bi bi-people-fill",
        ColorClass = "bg-success"
        })

    @await Html.PartialAsync("_Card", new CardData {
        Title = "Total Salary",
        Value = Model.TotalSalary.ToString(),
        IconClass = "bi bi-cash-stack",
        ColorClass = "bg-danger"
        })

    @await Html.PartialAsync("_Card", new CardData {
        Title = "Settled Salary",
        Value = Model.SettledSalary.ToString(),
        IconClass = "bi bi-check-circle",
        ColorClass = "bg-warning"
        })

    @await Html.PartialAsync("_Card", new CardData {
        Title = "Pending Salary",
        Value = Model.PendingSalary.ToString(),
        IconClass = "bi bi-exclamation-circle",
        ColorClass = "bg-info"
        })
</div>

<!-- Chart Panel -->
<div class="mt-2">
    <h6 class="mb-1">Payroll History</h6>

    <div class="row d-flex">

        <div class="w-50">
            <h1>chart box</h1>
        </div>

        <div class="w-50">
            <h1>chart box</h1>
        </div>

    </div>
</div>

<!-- Recent Payroll Table -->
<div class="mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6>Recent Payrolls</h6>
        <a asp-area="Employee" asp-controller="Employee" asp-action="Index" class="btn border px-4 py-2 text-decoration-none">View All</a>
    </div>

    @if (Model.RecentPayrolls == null || Model.RecentPayrolls.Count == 0)
    {
        <h5 class="text-muted">No recent payrolls available</h5>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0 table-responsive" style=" max-height:350px;">
                <table class="table table-hover">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Employee</th>
                            <th>Month</th>
                            <th>Basic</th>
                            <th>Deductions</th>
                            <th>Net Salary</th>
                        </tr>
                    </thead>
                    <tbody class="">
                        @foreach (var payroll in Model.RecentPayrolls)
                        {
                            <tr>
                                <td>@payroll.Name</td>
                                <td>@payroll.Month</td>
                                <td>₹@payroll.Gross</td>
                                <td>₹@payroll.Deduction</td>
                                <td class="fw-bold">₹@payroll.Net</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
