@{
    ViewData["Title"] = "Dashboard";
}
@model DashboardViewModel

<!-- Stats Cards -->
<div class="row g-2">

    @await Html.PartialAsync("_Card", new CardData {
    Title = "Total Employees",
        Value = Model.EmployeeCount.ToString(),
        IconClass = "bi bi-people-fill",
        ColorClass = "bg-success"
        })

    @await Html.PartialAsync("_Card", new CardData {
        Title = "Total Salary",
        Value = Model.TotalSalary.ToString(),
        IconClass = "bi bi-cash-stack",
        ColorClass = "bg-danger"
        })

    @await Html.PartialAsync("_Card", new CardData {
        Title = "Settled Salary",
        Value = Model.SettledSalary.ToString(),
        IconClass = "bi bi-check-circle",
        ColorClass = "bg-warning"
        })

    @await Html.PartialAsync("_Card", new CardData {
        Title = "Pending Salary",
        Value = Model.PendingSalary.ToString(),
        IconClass = "bi bi-exclamation-circle",
        ColorClass = "bg-info"
        })
</div>

<!-- Chart Panel -->
<div class="mt-2">
    <h6 class="mb-1">Payroll History</h6>

    <div class="row d-flex">

        <div class="w-50">
            <h1>chart box</h1>
        </div>

        <div class="w-50">
            <h1>chart box</h1>
        </div>

    </div>
</div>

<!-- Recent Payroll Table -->
<div class="mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6>Recent Payrolls</h6>
        <a asp-area="Employee" asp-controller="Employee" asp-action="Index" class="btn border px-4 py-2 text-decoration-none">Employee List</a>
    </div>

    @if (Model.RecentPayrolls == null || Model.RecentPayrolls.Count == 0)
    {
        <h5 class="text-muted">No recent payrolls available</h5>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0 table-responsive" style=" max-height:350px;">
                <table class="table table-hover">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Employee</th>
                            <th>Month</th>
                            <th>Basic</th>
                            <th>Deductions</th>
                            <th>Net Salary</th>
                        </tr>
                    </thead>
                    <tbody class="">
                        @foreach (var payroll in Model.RecentPayrolls)
                        {
                            <tr>
                                <td>@payroll.Name</td>
                                <td>@payroll.Month</td>
                                <td>₹@payroll.Gross</td>
                                <td>₹@payroll.Deduction</td>
                                <td class="fw-bold">₹@payroll.Net</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
