@{
    ViewData["Title"] = "Access Denied";
}

<div class="d-flex justify-content-center mt-2">
    <div class="card shadow-lg border-0 p-4 text-center" style="max-width: 450px; width: 100%;">

        <div class="mb-3">
            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 2rem;"></i>
        </div>

        <h2 class="text-danger fw-bold mb-2">Access Denied</h2>

        <p class="text-muted mb-3">
            @ViewBag.Message
        </p>

        <hr />

        <a href="/home" class="btn btn-outline-secondary w-100 mt-2">
            ⬅ Back to Login
        </a>
    </div>
</div>