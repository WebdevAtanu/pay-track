@{
    ViewData["Title"] = "Authentication";
}

<div class="hero-container d-flex align-items-center justify-content-center">
    <div class="card shadow auth-card p-4 text-center bg-white w-full">
        <!-- Avatar -->
        <div class="text-center">
            @* <img src="https://i.pravatar.cc/100" class="avatar shadow" /> *@
            <img src="~/images/avatar.jpg" class="avatar shadow" />
        </div>

        <!-- Title -->
        <h3 class="fw-bold mt-2 text-black-50" id="formTitle">Login</h3>
        <p class="text-muted">Access your account</p>

        <div class="form-container">
            <!-- Login Form -->
            <form id="loginForm" class="form-box active p-2">
                <div class="mb-2 text-start">
                    <label>Email</label>
                    <input type="email" class="form-control" placeholder="Enter email" required />
                </div>

                <div class="mb-2 text-start">
                    <label>Password</label>
                    <input type="password" class="form-control" placeholder="Enter password" required />
                </div>

                <button class="btn btn-primary w-100">Login</button>
            </form>

            <!-- Signup Form -->
            <form id="signupForm" class="form-box p-2">
                <div class="mb-2 text-start">
                    <label>Name</label>
                    <input type="text" class="form-control" placeholder="Enter name" required />
                </div>

                <div class="mb-2 text-start">
                    <label>Email</label>
                    <input type="email" class="form-control" placeholder="Enter email" required />
                </div>

                <div class="mb-2 text-start">
                    <label>Password</label>
                    <input type="password" class="form-control" placeholder="Create password" required />
                </div>

                <button class="btn btn-success w-100">Sign Up</button>
            </form>
        </div>
        <hr class="m-0" />
        <!-- Toggle -->
        <div class="mt-3">
            <small id="toggleText">
                Don't have an account?
                <span class="toggle-link" onclick="toggleForm()">Sign Up</span>
            </small>
        </div>
    </div>
</div>