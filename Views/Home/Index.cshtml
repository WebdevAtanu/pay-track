@{
    ViewData["Title"] = "Dashboard";
}
@model DashboardViewModel

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Dashboard</h2>
        <span class="text-muted">Welcome back, Admin</span>
    </div>

    <!-- Stats Cards -->

    <div class="row g-4">

        <!-- Total Employees -->
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-3 p-3">
                <div class="d-flex align-items-center gap-3">

                    <div class="bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center rounded-3"
                         style="width:60px; height:60px;">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>

                    <div>
                        <h6 class="text-muted mb-1">Total Employees</h6>
                        <h3 class="fw-bold mb-0">@Model.EmployeeCount</h3>
                    </div>

                </div>
            </div>
        </div>

        <!-- Total Salary -->
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-3 p-3">
                <div class="d-flex align-items-center gap-3">

                    <div class="bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center rounded-3"
                         style="width:60px; height:60px;">
                        <i class="bi bi-cash-stack fs-4"></i>
                    </div>

                    <div>
                        <h6 class="text-muted mb-1">Total Salary</h6>
                        <h3 class="fw-bold mb-0">₹@Model.TotalSalary</h3>
                    </div>

                </div>
            </div>
        </div>

        <!-- Settled Salary -->
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-3 p-3">
                <div class="d-flex align-items-center gap-3">

                    <div class="bg-info bg-opacity-10 text-info d-flex align-items-center justify-content-center rounded-3"
                         style="width:60px; height:60px;">
                        <i class="bi bi-check-circle fs-4"></i>
                    </div>

                    <div>
                        <h6 class="text-muted mb-1">Settled Salary</h6>
                        <h3 class="fw-bold mb-0 text-success">₹@Model.SettledSalary</h3>
                    </div>

                </div>
            </div>
        </div>

        <!-- Pending Salary -->
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-3 p-3">
                <div class="d-flex align-items-center gap-3">

                    <div class="bg-danger bg-opacity-10 text-danger d-flex align-items-center justify-content-center rounded-3"
                         style="width:60px; height:60px;">
                        <i class="bi bi-exclamation-circle fs-4"></i>
                    </div>

                    <div>
                        <h6 class="text-muted mb-1">Pending Salary</h6>
                        <h3 class="fw-bold mb-0 text-danger">₹@Model.PendingSalary</h3>
                    </div>

                </div>
            </div>
        </div>

    </div>

    <!-- Quick Actions -->
    <div class="mt-5">
        <h4 class="mb-3">Quick Actions</h4>

        <div class="row g-3">

            <div class="col-md-3">
                <a href="/Employee/Create" class="btn btn-primary w-100 p-3">
                    ➕ Add Employee
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Payroll/Generate" class="btn btn-success w-100 p-3">
                    💰 Generate Payroll
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Reports" class="btn btn-warning w-100 p-3">
                    📊 View Reports
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Settings" class="btn btn-dark w-100 p-3">
                    ⚙️ Settings
                </a>
            </div>

        </div>
    </div>

    <!-- Recent Payroll Table -->
    <div class="mt-5">
        <h4 class="mb-3">Recent Payrolls</h4>

        <div class="card shadow-sm">
            <div class="card-body table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Employee</th>
                            <th>Month</th>
                            <th>Basic</th>
                            <th>Bonus</th>
                            <th>Deductions</th>
                            <th>Net Salary</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Rahul Sharma</td>
                            <td>March 2026</td>
                            <td>₹30,000</td>
                            <td>₹5,000</td>
                            <td>₹2,000</td>
                            <td class="fw-bold">₹33,000</td>
                        </tr>
                        <tr>
                            <td>Priya Das</td>
                            <td>March 2026</td>
                            <td>₹28,000</td>
                            <td>₹3,000</td>
                            <td>₹1,500</td>
                            <td class="fw-bold">₹29,500</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>