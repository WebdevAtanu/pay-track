@{
    ViewData["Title"] = "Authentication";
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <div asp-validation-summary="All" class="text-danger"></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="hero-container d-flex justify-content-center">
    <div class="card shadow auth-card p-4 text-center bg-white w-full h-100 mt-4">
        <!-- Avatar -->
        <div class="text-center">
            @* <img src="https://i.pravatar.cc/100" class="avatar shadow" /> *@
            <img src="~/images/avatar.jpg" class="avatar shadow" />
        </div>

        <!-- Title -->
        <h3 class="fw-bold mt-2 text-black-50" id="formTitle">Login</h3>
        <p class="text-muted">Access your account</p>

        <div class="form-container">
            <!-- Login Form -->
            <form id="loginForm" class="form-box active p-2" method="post" asp-action="Login">
                <div class="mb-2 text-start">
                    <label>Email</label>
                    <input type="email" name="Email" class="form-control" placeholder="Enter email" required />
                </div>

                <div class="mb-2 text-start">
                    <label>Password</label>
                    <input type="password" name="Password" class="form-control" placeholder="Enter password" required />
                </div>

                <button class="btn btn-primary w-100">Login</button>
            </form>

            <!-- Signup Form -->
            <form id="signupForm" class="form-box p-2" method="post" asp-action="Register">
                <div class="mb-2 text-start">
                    <label>Name</label>
                    <input type="text" name="Name" class="form-control" placeholder="Enter name" required />
                </div>

                <div class="mb-2 text-start">
                    <label>Email</label>
                    <input type="email" name="Email" class="form-control" placeholder="Enter email" required />
                </div>

                <div class="mb-2 text-start">
                    <label>Password</label>
                    <input type="password" name="Password" class="form-control" placeholder="Create password" required />
                </div>

                <button class="btn btn-success w-100">Sign Up</button>
            </form>
        </div>
        <hr class="m-0" />
        <!-- Toggle -->
        <div class="mt-3">
            <small id="toggleText">
                Don't have an account?
                <span class="toggle-link" onclick="toggleForm()">Sign Up</span>
            </small>
        </div>
    </div>
</div>